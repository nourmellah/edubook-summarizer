APP_NAME="Education AI Summary Service"
APP_VERSION="0.9.0"
HOST="0.0.0.0"
PORT="8001"

STORAGE_DIR="app/storage"
KEEP_UPLOADED_FILES="true"
MAX_UPLOAD_SIZE_MB="50"
MAX_TOTAL_UPLOAD_SIZE_MB="150"
MAX_FILES_PER_REQUEST="8"
ALLOWED_ORIGINS="*"

# LLM provider:
# - ollama: fully local model through Ollama
# - gemini: online Google Gemini API
# - auto: use Gemini if GEMINI_API_KEY exists, otherwise Ollama
LLM_PROVIDER="auto"

# Local Ollama provider
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_TIMEOUT_SECONDS="300"
OLLAMA_TEMPERATURE="0.2"
OLLAMA_NUM_PREDICT="1800"
OLLAMA_NUM_CTX="8192"

# Online Gemini provider
# Create an API key in Google AI Studio, then paste it here.
# Keep .env private and do not commit it to Git.
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# Recommended default for rate limits / cost / speed.
# Use gemini-2.5-flash for better quality if your quota allows it.
GEMINI_MODEL="gemini-2.5-flash-lite"
GEMINI_TIMEOUT_SECONDS="600"
GEMINI_TEMPERATURE="0.2"
GEMINI_MAX_OUTPUT_TOKENS="9000"

# Gemini rate-limit protection
# For study_pack, Gemini uses one rich request instead of many chapter requests.
GEMINI_SINGLE_CALL_STUDY_PACK="true"
GEMINI_STUDY_PACK_MAX_INPUT_CHARS="90000"
GEMINI_RETRY_ATTEMPTS="2"
GEMINI_RETRY_DEFAULT_WAIT_SECONDS="50"
GEMINI_RETRY_MAX_WAIT_SECONDS="75"
GEMINI_FALLBACK_TO_OLLAMA="true"

# Summary modes:
# - study_pack: default educational summary. With Gemini, this is automatically single-call to protect rate limits.
# - gemini_single / rate_safe: force one-call study-pack generation.
# - fast: quicker, less detailed.
# - detailed: slower chunk-based map-reduce.
SUMMARY_MODE="study_pack" 
SUMMARY_LANGUAGE="fr" 								# en - fr - ar - de - auto
SUMMARY_STYLE="student_friendly" 		# fast - study_pack - exam_revision - academic - cheatsheet
DEFAULT_OUTPUT_FORMAT="both" 				# json - pdf - tex - both (tex + pdf)

# TeX output
# Safer strategy: preserve prose; optionally add a curated key-formula section.
TEX_INCLUDE_FORMULA_BOX="true"
TEX_MAX_FORMULA_CARDS="16"

# Study-pack mode for local Ollama / multi-call fallback
STUDY_PACK_MAX_SECTIONS="8"
STUDY_PACK_CHAPTER_MAX_CHARS="9000"
STUDY_PACK_CHAPTER_NUM_PREDICT="1400"
STUDY_PACK_CHAPTER_TIMEOUT_SECONDS="300"
STUDY_PACK_FINAL_NUM_PREDICT="2200"
STUDY_PACK_FINAL_TIMEOUT_SECONDS="420"
STUDY_PACK_PAGES_PER_SECTION="35"

# Fast mode
FAST_SUMMARY_MAX_INPUT_CHARS="18000"
FAST_SUMMARY_NUM_PREDICT="1800"
FAST_SUMMARY_TIMEOUT_SECONDS="300"

# Detailed mode
MAX_CHARS_PER_CHUNK="9000"
MAX_CHUNKS="40"
CHUNK_SUMMARY_NUM_PREDICT="700"
FINAL_SUMMARY_NUM_PREDICT="1800"
